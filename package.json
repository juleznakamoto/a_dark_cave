{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "main": "dist-electron/main.cjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "NODE_ENV=development NODE_OPTIONS='--max-old-space-size=4096' tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:steam": "cross-env VITE_STEAM_BUILD=1 vite build",
    "electron:build": "node scripts/build-electron.mjs",
    "electron:start": "electron .",
    "electron:dev": "npm run build:steam && npm run electron:build && electron .",
    "electron:package": "npm run build:steam && npm run electron:build && electron-builder --win",
    "steam:stage": "powershell -ExecutionPolicy Bypass -File scripts/steam-upload.ps1 -StageOnly",
    "steam:upload": "powershell -ExecutionPolicy Bypass -File scripts/steam-upload.ps1",
    "steam:upload-only": "powershell -ExecutionPolicy Bypass -File scripts/steam-upload.ps1 -UploadOnly",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:gender": "node scripts/test-gender-service.js",
    "i18n:extract": "node scripts/extract-i18n.mjs",
    "i18n:translate": "node scripts/translate-locales.mjs",
    "i18n:events:extract": "node scripts/extract-events-i18n.mjs",
    "i18n:events:migrate": "node scripts/extract-events-i18n.mjs && node scripts/migrate-events-i18n.mjs && node scripts/sync-locale-keys.mjs",
    "i18n:verify": "node scripts/list-unmigrated-events.mjs && node scripts/check-event-coverage.mjs && node scripts/audit-i18n-ui.mjs && node scripts/audit-locale-length.mjs --check && vitest run client/src/i18n/",
    "i18n:sync": "node scripts/sync-locale-keys.mjs && node scripts/fill-identical-locale-strings.mjs && node scripts/audit-locale-length.mjs --write",
    "export:resend-csvs": "tsx scripts/export-resend-contact-csvs.ts"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.3.0",
    "@supabase/supabase-js": "^2.78.0",
    "@tanstack/react-query": "^5.60.5",
    "@types/compression": "^1.8.1",
    "@types/howler": "^2.2.12",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.4.23",
    "bad-words": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "date-fns": "^3.6.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-static-gzip": "^2.2.0",
    "framer-motion": "^11.18.2",
    "howler": "^2.2.4",
    "html-to-image": "^1.11.13",
    "i18next": "^26.2.0",
    "idb": "^8.0.3",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^17.0.8",
    "react-refresh": "^0.18.0",
    "recharts": "^2.15.4",
    "steamworks.js": "^0.4.0",
    "stripe": "^19.2.0",
    "supertest": "^7.1.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.3.5",
    "ws": "^8.21.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "^0.3.0",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/ui": "^4.0.14",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.30.4",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^3.4.17",
    "terser": "^5.36.0",
    "tsx": "^4.19.1",
    "typescript": "5.6.3",
    "vite": "^5.4.19",
    "vite-plugin-compression2": "^2.4.0",
    "vitest": "^4.0.14"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
