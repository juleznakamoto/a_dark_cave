# Internal only - never commit real values. Not used by the main app.
# Set these when running the gender service locally.
GENDER_SERVICE_TOKEN=your-secret-token-here
GENDER_SERVICE_PORT=5001
# Max popularity rank (lower = more common) to accept a match. Optional; defaults shown.
GENDER_EMAIL_MAX_RANK=5000
GENDER_NAME_MAX_RANK=10000
